{
  "@context": [
    "http://www.w3.org/ns/dx/prof/profilesont",
    {
      "dct": "http://purl.org/dc/terms/",
      "prof": "http://www.w3.org/ns/dx/prof#",
      "role": "http://www.w3.org/ns/dx/prof/role/"
    }
  ],
  "@id": "https://openchain.graph/profiles/iso20022/pacs.008-subset",
  "@type": ["dct:Standard", "prof:Profile"],
  "dct:title": "OpenChainGraph ISO 20022 pacs.008 payment/settlement subset",
  "dct:description": "An OpenChainGraph profile that maps the financial payload of a decision artifact to a curated subset of ISO 20022 pacs.008 (FIToFICustomerCreditTransfer) business elements: amount, parties (debtor/creditor), agents (debtor/creditor agent), settlement date, and remittance information. ISO 20022-ALIGNED, not a registered ISO 20022 message. External code lists (ISO 4217/3166/9362/13616/17442) are adopted by reference. This profile NEVER enters the execution_hash preimage — it is JSON-LD framing only.",
  "dct:identifier": "iso20022:pacs.008-subset",
  "dct:issued": "2026-06-08",
  "dct:modified": "2026-06-18",
  "dct:publisher": { "@id": "https://postoaklabs.com", "dct:title": "Post Oak Labs" },
  "prof:isProfileOf": [
    { "@id": "https://www.iso20022.org/", "dct:title": "ISO 20022" },
    { "@id": "https://openchain.graph/spec/v0.3/context.jsonld", "dct:title": "OpenChainGraph v0.3 base context" }
  ],
  "prof:hasToken": "iso20022:pacs.008-subset",
  "prof:hasResource": [
    {
      "@type": "prof:ResourceDescriptor",
      "dct:title": "ISO 20022 overlay JSON-LD context (machine-readable schema)",
      "prof:hasRole": { "@id": "role:schema" },
      "dct:format": "application/ld+json",
      "prof:hasArtifact": { "@id": "https://openchain.graph/spec/v0.3/iso20022-context.jsonld" }
    },
    {
      "@type": "prof:ResourceDescriptor",
      "dct:title": "ISO 20022 alignment + pacs.008 crosswalk guide (human-readable)",
      "prof:hasRole": { "@id": "role:guidance" },
      "dct:format": "text/html",
      "prof:hasArtifact": { "@id": "https://openchain.graph/guide-iso20022.html" }
    }
  ],
  "ocg:applies_to": "Nodes whose payload is a payment/settlement/transfer carrying amount + parties + agents (e.g. x402 settlement, VoP matching, ISO 20022 address migration, and Tempo TIP-20 settlement nodes).",
  "ocg:fields": ["instructed_amount", "amount", "currency", "debtor", "creditor", "party_name", "lei", "debtor_agent", "creditor_agent", "bicfi", "iban", "settlement_date", "remittance_information", "country"],
  "ocg:hash_preimage": "unchanged — this profile is outside the execution_hash preimage (sorted-key SHA-256 over {policy_parameters, output_payload} only)"
}
