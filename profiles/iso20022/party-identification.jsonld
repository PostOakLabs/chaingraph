{
  "@context": [
    "http://www.w3.org/ns/dx/prof/profilesont",
    {
      "dct": "http://purl.org/dc/terms/",
      "prof": "http://www.w3.org/ns/dx/prof#",
      "role": "http://www.w3.org/ns/dx/prof/role/"
    }
  ],
  "@id": "https://openchain.graph/profiles/iso20022/party-identification",
  "@type": ["dct:Standard", "prof:Profile"],
  "dct:title": "OpenChainGraph ISO 20022 PartyIdentification subset",
  "dct:description": "An OpenChainGraph profile for decision artifacts whose payload carries party / issuer / legal-entity identity WITHOUT a transaction. A strict subset — party_name + LEI (+ optional country/currency) — named after the ISO 20022 PartyIdentification / OrganisationIdentification element used in the REDA (reference data) and ACMT (account management) message families, which standardize LEI-based party identity outside of payments. Contains NO amount, agent, or settlement fields. ISO 20022-ALIGNED, not a registered ISO 20022 message. NEVER enters the execution_hash preimage.",
  "dct:identifier": "iso20022:party-identification",
  "dct:issued": "2026-06-18",
  "dct:modified": "2026-06-18",
  "dct:publisher": { "@id": "https://postoaklabs.com", "dct:title": "Post Oak Labs" },
  "prof:isProfileOf": [
    { "@id": "https://www.iso20022.org/", "dct:title": "ISO 20022 (REDA / ACMT PartyIdentification)" },
    { "@id": "https://openchain.graph/spec/v0.3/context.jsonld", "dct:title": "OpenChainGraph v0.3 base context" }
  ],
  "prof:hasToken": "iso20022:party-identification",
  "prof:hasResource": [
    {
      "@type": "prof:ResourceDescriptor",
      "dct:title": "ISO 20022 overlay JSON-LD context (party terms: party_name, lei, country, currency)",
      "prof:hasRole": { "@id": "role:schema" },
      "dct:format": "application/ld+json",
      "prof:hasArtifact": { "@id": "https://openchain.graph/spec/v0.3/iso20022-context.jsonld" }
    },
    {
      "@type": "prof:ResourceDescriptor",
      "dct:title": "Profile-conformance guide (human-readable)",
      "prof:hasRole": { "@id": "role:guidance" },
      "dct:format": "text/html",
      "prof:hasArtifact": { "@id": "https://openchain.graph/guide-profiles.html" }
    }
  ],
  "ocg:applies_to": "Nodes whose payload binds a legal entity (issuer, validator, regulated party) by name + LEI without a transaction — e.g. PPSI issuer-config, validator-readiness, entity readiness scores.",
  "ocg:fields": ["party_name", "lei", "country", "currency"],
  "ocg:hash_preimage": "unchanged — this profile is outside the execution_hash preimage"
}
